# Auto-detect text files; normalize to LF in the repo, native on checkout.
* text=auto eol=lf

# Windows-only scripts: keep CRLF so they run when downloaded as a ZIP.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf
*.iss        text eol=crlf

# Source files: enforce LF.
*.py         text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.txt        text eol=lf

# Treat as binary so git diff doesn't try to merge.
*.ico        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.zip        binary
*.exe        binary
*.dll        binary
*.pyd        binary
*.onnx       binary
*.ttf        binary
*.otf        binary
*.woff       binary
*.woff2      binary

# GitHub linguist: don't count vendored code in language stats
docs/**          linguist-documentation
assets/**        linguist-vendored
tests/fixtures/* linguist-generated
